# ═══════════════════════════════════════════════════
# SAIFEN — variáveis de ambiente (exemplo)
# Copie para `.env` e preencha. NUNCA commite o `.env`.
# ═══════════════════════════════════════════════════

# ─── Supabase (pipeline + scripts/push_to_supabase.py) ──────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...                # service_role (server-side)
SUPABASE_ANON_KEY=eyJhbGciOi...                   # anon (frontend)

# ─── Web (injetado em runtime, opcional) ────────────────────
# window.__SAIFEN_SUPABASE_URL__       (configurado pelo build/deploy)
# window.__SAIFEN_SUPABASE_ANON_KEY__

# ─── Mobile (lido pelo Expo Constants) ──────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
EXPO_PUBLIC_SHARED_BASE=http://192.168.1.42:8000/shared
